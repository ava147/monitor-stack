groups:
- name: host_alerts
  rules:
  # 1. CPU 使用率 > 80% 告警
  - alert: HighCpuUsage
    expr: 100 - (avg by (instance) (rate(node_cpu_seconds_total{mode="idle"}[5m])) * 100) > 1
    for: 1m
    labels:
      severity: warning
    annotations:
      summary: "CPU 使用率过高 (实例 {{ $labels.instance }})"
      description: "CPU 使用率已经超过 1% (当前值: {{ $value }}%)"

  # 2. 磁盘使用率 > 90% 告警
  - alert: HighDiskUsage
    expr: 100 - (node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"} * 100) > 90
    for: 1m
    labels:
      severity: warning
    annotations:
      summary: "磁盘空间不足 (实例 {{ $labels.instance }})"
      description: "根分区磁盘使用率超过 90% (当前值: {{ $value }}%)"
